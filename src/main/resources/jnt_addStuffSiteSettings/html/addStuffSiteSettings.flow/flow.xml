<?xml version="1.0" encoding="UTF-8"?>
<flow xmlns="http://www.springframework.org/schema/webflow"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.springframework.org/schema/webflow
        http://www.springframework.org/schema/webflow/spring-webflow-2.0.xsd">

    <var name="flowHandler" class="org.jahia.modules.addStuff.sitesettings.AddStuffSiteSettingsFlowHandler"/>

    <view-state id="addStuffSettings">
        <on-render>
            <evaluate expression="flowHandler.getSiteNode(flowRequestContext)" result="requestScope.siteNode"/>
        </on-render>
        <transition on="cancel" to="addStuffSettings" bind="false" validate="false"/>
        <transition on="save" to="addStuffSettings">
            <evaluate expression="flowHandler.saveSettings(
                flowRequestContext,
                requestParameters.addStuffHeadTop,
                requestParameters.addStuffHead,
                requestParameters.addStuffBodyTop,
                requestParameters.addStuffBody)"/>
        </transition>
    </view-state>

</flow>
